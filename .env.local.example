# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub PAT for repo access (needs 'repo' scope)
GITHUB_TOKEN=

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Allowed editors (comma-separated GitHub emails)
ALLOWED_EMAILS=nick@alkemeins.com
